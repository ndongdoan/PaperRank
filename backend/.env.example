# --- API Config ---
# Semantic Scholar, at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY="your_api_key_here"

# --- Caching ---
# "true" to use Redis (for deployment), "false" to use Diskcache (local testing)
USE_REDIS="false"
# URL from Upstash or Render Redis
REDIS_URL=""

# --- Security ---
# Allowed Domain
ALLOWED_ORIGINS="http://localhost:3000,https://your-app.vercel.app"
